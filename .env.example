# Copy to .env and fill in. Real .env is gitignored.
#
# Only required if you want AI-generated voiceover. Without it, ship videos
# with your own pre-recorded VO MP3s under public/assets/voice/generated/.
ELEVENLABS_API_KEY=

# Optional. Default 4747 ("SFX" on a dial pad). Override if you already have
# something on that port.
AUDITIONER_PORT=4747
